generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String?
  passwordHash     String?
  role             String    @default("PARENT")
  image            String?
  stripeCustomerId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  children      Child[]
  orders        Order[]
  teacher       Teacher?
  teacherOrders TeacherOrder[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model School {
  id            String   @id @default(cuid())
  name          String
  address       String?
  timezone      String   @default("America/New_York")
  cutoffMinutes Int      @default(480)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  teachers  Teacher[]
  menuItems MenuItem[]
  settings  SchoolSettings?

  @@map("schools")
}

model SchoolSettings {
  id                   String  @id @default(cuid())
  schoolId             String  @unique
  allowRecurringOrders Boolean @default(true)
  maxItemsPerOrder     Int     @default(10)
  taxRate              Float   @default(0.0)

  school School @relation(fields: [schoolId], references: [id])

  @@map("school_settings")
}

model Teacher {
  id         String   @id @default(cuid())
  userId     String   @unique
  schoolId   String
  firstName  String
  lastName   String
  grade      String?
  roomNumber String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school   School   @relation(fields: [schoolId], references: [id])
  children Child[]
  orders   Order[]

  @@map("teachers")
}

model Child {
  id        String   @id @default(cuid())
  parentId  String
  teacherId String
  firstName String
  lastName  String
  allergies String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent         User                 @relation(fields: [parentId], references: [id], onDelete: Cascade)
  teacher        Teacher              @relation(fields: [teacherId], references: [id])
  orders         Order[]
  recurringRules RecurringOrderRule[]

  @@map("children")
}

model MenuItem {
  id           String   @id @default(cuid())
  schoolId     String
  name         String
  description  String?
  price        Int
  category     String
  imageUrl     String?
  isAvailable  Boolean  @default(true)
  isFamilySize Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school             School                  @relation(fields: [schoolId], references: [id])
  orderItems         OrderItem[]
  teacherOrderItems  TeacherOrderItem[]
  recurringRuleItems RecurringOrderRuleItem[]

  @@map("menu_items")
}

model Order {
  id                    String   @id @default(cuid())
  parentId              String
  childId               String
  teacherId             String
  deliveryDate          DateTime
  status                String   @default("PENDING")
  subtotalCents         Int      @default(0)
  taxCents              Int      @default(0)
  totalCents            Int      @default(0)
  stripePaymentIntentId String?  @unique
  stripePaymentMethodId String?
  notes                 String?
  isRecurring           Boolean  @default(false)
  recurringRuleId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  parent        User                @relation(fields: [parentId], references: [id])
  child         Child               @relation(fields: [childId], references: [id])
  teacher       Teacher             @relation(fields: [teacherId], references: [id])
  items         OrderItem[]
  recurringRule RecurringOrderRule? @relation(fields: [recurringRuleId], references: [id])

  @@index([deliveryDate])
  @@index([teacherId, deliveryDate])
  @@index([parentId])
  @@map("orders")
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  menuItemId String
  quantity   Int    @default(1)
  unitPrice  Int
  totalPrice Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@map("order_items")
}

model RecurringOrderRule {
  id         String    @id @default(cuid())
  parentId   String
  childId    String
  startDate  DateTime
  endDate    DateTime?
  daysOfWeek String
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  child           Child                   @relation(fields: [childId], references: [id], onDelete: Cascade)
  ruleItems       RecurringOrderRuleItem[]
  generatedOrders Order[]

  @@map("recurring_order_rules")
}

model RecurringOrderRuleItem {
  id         String @id @default(cuid())
  ruleId     String
  menuItemId String
  quantity   Int    @default(1)

  rule     RecurringOrderRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  menuItem MenuItem           @relation(fields: [menuItemId], references: [id])

  @@map("recurring_order_rule_items")
}

model TeacherOrder {
  id                    String   @id @default(cuid())
  userId                String
  deliveryDate          DateTime
  status                String   @default("PENDING")
  subtotalCents         Int      @default(0)
  totalCents            Int      @default(0)
  stripePaymentIntentId String?  @unique
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id])
  items TeacherOrderItem[]

  @@map("teacher_orders")
}

model TeacherOrderItem {
  id             String @id @default(cuid())
  teacherOrderId String
  menuItemId     String
  quantity       Int    @default(1)
  unitPrice      Int
  totalPrice     Int

  teacherOrder TeacherOrder @relation(fields: [teacherOrderId], references: [id], onDelete: Cascade)
  menuItem     MenuItem     @relation(fields: [menuItemId], references: [id])

  @@map("teacher_order_items")
}
